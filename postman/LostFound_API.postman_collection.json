{
  "info": {
    "_postman_id": "lostfound-api-collection",
    "name": "Lost-Found API",
    "description": "Sanctum API for Campus Found. Includes authentication, owned report CRUD, pending claim verification, and owner review.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api"
    },
    {
      "key": "owner_token",
      "value": ""
    },
    {
      "key": "claimant_token",
      "value": ""
    },
    {
      "key": "item_id",
      "value": "1"
    },
    {
      "key": "claim_id",
      "value": "1"
    },
    {
      "key": "email",
      "value": "admin@rupp.edu.kh"
    },
    {
      "key": "password",
      "value": "password"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login succeeded', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('owner_token', json.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{base_url}}/login"
          }
        },
        {
          "name": "Register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('register_email', `user-${Date.now()}@rupp.edu.kh`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Register succeeded', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('claimant_token', json.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"API Tester\",\n  \"email\": \"{{register_email}}\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{base_url}}/register"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{claimant_token}}"
              }
            ],
            "url": "{{base_url}}/logout"
          }
        },
        {
          "name": "Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{claimant_token}}"
              }
            ],
            "url": "{{base_url}}/user"
          }
        }
      ]
    },
    {
      "name": "Items",
      "item": [
        {
          "name": "List Items",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/items?status=all&sort=desc",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "items"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "all"
                },
                {
                  "key": "sort",
                  "value": "desc"
                },
                {
                  "key": "search",
                  "value": "",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Get Item",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/items/{{item_id}}"
          }
        },
        {
          "name": "Report Item (create)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) { pm.collectionVariables.set('item_id', json.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{owner_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Blue Umbrella\",\n  \"status\": \"found\",\n  \"category\": \"bottle_umbrella\",\n  \"created_at\": \"2026-05-29T12:00:00\",\n  \"location\": \"Building A, 2nd floor\",\n  \"contact_info\": \"telegram @student\",\n  \"description\": \"Foldable umbrella with campus sticker\",\n  \"verification_question\": \"What color is the handle?\",\n  \"verification_answer\": \"black\",\n  \"hidden_details\": \"Small scratch beside the campus sticker\"\n}"
            },
            "url": "{{base_url}}/items"
          }
        }
      ]
    },
    {
      "name": "Claims",
      "item": [
        {
          "name": "List Claims",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/claims?type=all&sort=desc",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "claims"
              ],
              "query": [
                {
                  "key": "type",
                  "value": "all",
                  "description": "all, claim, found, or return"
                },
                {
                  "key": "sort",
                  "value": "desc"
                },
                {
                  "key": "status",
                  "value": "approved",
                  "description": "pending, approved, or rejected",
                  "disabled": true
                },
                {
                  "key": "category",
                  "value": "ticket",
                  "description": "Examples: ticket, id_card, bottle_umbrella, electronic, wallet, key, book, clothes_accessories, other",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Submit Claim / Found Report",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Claim created', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) { pm.collectionVariables.set('claim_id', json.data.id); }",
                  "pm.test('Claim waits for owner review', function () { pm.expect(json.data.status).to.eql('pending'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{claimant_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"item_id\": \"{{item_id}}\",\n  \"claimant_name\": \"API Claimant\",\n  \"contact_info\": \"telegram @claimant\",\n  \"message\": \"I lost this umbrella near Building A.\",\n  \"verification_answer\": \"black\"\n}"
            },
            "url": "{{base_url}}/claims"
          }
        },
        {
          "name": "Get Claim",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{claimant_token}}"
              }
            ],
            "url": "{{base_url}}/claims/{{claim_id}}"
          }
        },
        {
          "name": "Approve Claim",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{owner_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\"\n}"
            },
            "url": "{{base_url}}/claims/{{claim_id}}/status"
          }
        },
        {
          "name": "Reject Claim",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{owner_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"rejected\"\n}"
            },
            "url": "{{base_url}}/claims/{{claim_id}}/status"
          }
        },
        {
          "name": "Delete Claim",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{claimant_token}}"
              }
            ],
            "url": "{{base_url}}/claims/{{claim_id}}"
          }
        }
      ]
    },
    {
      "name": "Owned Item Management",
      "item": [
        {
          "name": "Delete Item",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{owner_token}}"
              }
            ],
            "url": "{{base_url}}/items/{{item_id}}"
          }
        }
      ]
    }
  ]
}
